---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  structuredData?: object;
}

// Markdown pages deliver their frontmatter under Astro.props.frontmatter, while
// .astro pages pass these as direct props. Support both.
const fm = (Astro.props as Record<string, any>).frontmatter ?? {};
const title = Astro.props.title ?? fm.title;
const description = Astro.props.description ?? fm.description;
const noindex = Astro.props.noindex ?? fm.noindex;
const baseStructured = Astro.props.structuredData ?? fm.structuredData;

// Blog pages get a BreadcrumbList (Home > Blog > Post). Generated from the URL,
// so every new post picks it up automatically.
const SITE = 'https://www.q-tune.com';
const pathname = Astro.url.pathname;
const isBlog = pathname.startsWith('/blog');
const isBlogPost = isBlog && pathname.replace(/\/$/, '') !== '/blog';
let breadcrumb: object | undefined;
if (isBlog) {
  const itemListElement: object[] = [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog/` },
  ];
  if (isBlogPost) {
    itemListElement.push({
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: new URL(pathname, SITE).href,
    });
  }
  breadcrumb = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement,
  };
}

const structuredData = breadcrumb
  ? baseStructured
    ? [baseStructured, breadcrumb]
    : breadcrumb
  : baseStructured;
---

<BaseLayout title={title} description={description} noindex={noindex} structuredData={structuredData}>
  <!-- Title banner -->
  <div class="border-b border-cream-border bg-cream-muted">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 py-8 sm:py-12">
      <h1 class="text-3xl sm:text-4xl font-heading font-bold">{title}</h1>
    </div>
  </div>

  <!-- Content area -->
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-8 sm:py-12">
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </div>
</BaseLayout>
