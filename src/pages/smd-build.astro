---
// Permanent QR-code entry point — this URL is printed on the PCB and in the
// assembly guide, so it must NEVER be renamed. It records the scan in GA, then
// redirects instantly to the current assembly page.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>Q-Tune Assembly</title>
    <meta http-equiv="refresh" content="0;url=/assembly/" />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-CVGF0BKRZD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      // beacon transport ensures the event still sends as we navigate away
      gtag('config', 'G-CVGF0BKRZD', { transport_type: 'beacon' });
      gtag('event', 'qr_scan', {
        page_path: '/smd-build',
        page_title: 'PCB QR Scan',
      });
      window.location.replace('/assembly/');
    </script>
  </head>
  <body>
    <p>Redirecting to the <a href="/assembly/">Q-Tune Assembly Guide</a>&hellip;</p>
  </body>
</html>
