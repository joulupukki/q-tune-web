---
interface Props {
  name: string;
  variant: string;
  price: number;
  stripeUrl: string;
  buttonLabel: string;
  status?: 'available' | 'preorder' | 'soldout';
}

const { name, price, stripeUrl, buttonLabel, status = 'available' } = Astro.props;
const isPreorder = status === 'preorder';
const isSoldOut = status === 'soldout';
---

<div
  class:list={[
    'bg-cream-surface border border-cream-border rounded-xl p-6 text-center transition-all duration-300',
    isSoldOut ? 'opacity-75' : 'hover:border-amber-glow/40 hover:shadow-lg hover:-translate-y-1',
  ]}
>
  <div class="text-lg font-heading font-semibold text-text-heading mb-1">
    <strong>{name}</strong> Kit
  </div>
  {isPreorder && (
    <div class="text-sm font-semibold text-amber-dark mb-3">
      PRE-ORDER<br />SHIPS JUNE&ndash;JULY 2026
    </div>
  )}
  {isSoldOut && (
    <div class="text-sm font-semibold text-text-muted mb-3">
      TEMPORARILY<br />SOLD OUT
    </div>
  )}
  {!isPreorder && !isSoldOut && (
    <div class="text-sm font-semibold text-success mb-3">
      IN STOCK &<br />READY TO SHIP
    </div>
  )}
  <div class="text-4xl font-bold text-text-heading mb-1">${price}</div>
  <div class="text-sm text-text-muted mb-4">+ FREE Shipping</div>

  {isSoldOut ? (
    <button
      type="button"
      disabled
      class="w-full py-3 px-6 bg-cream-muted text-text-muted font-semibold rounded-lg cursor-not-allowed"
    >
      Sold Out
    </button>
  ) : (
    <button
      class="buy-btn w-full py-3 px-6 bg-amber-glow text-white font-semibold rounded-lg hover:bg-amber-dark transition-all duration-200 shadow-md hover:shadow-lg active:scale-[0.98]"
      data-url-us={stripeUrl}
    >
      {buttonLabel}
    </button>
  )}

  <slot />
</div>
