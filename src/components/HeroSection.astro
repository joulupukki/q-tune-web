---
import { qTuneProduct } from '../data/products';
---

<section class="relative overflow-hidden bg-dark-bg text-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 sm:py-20">
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
      <!-- Text -->
      <div class="flex-1 text-center lg:text-left">
        <span class="inline-block px-3 py-1 mb-4 rounded-full bg-amber-glow/15 text-amber-light text-xs font-bold uppercase tracking-wide">
          No Soldering Required
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-4 text-white">
          Build Your Own Pro-Grade Tuner Pedal
        </h1>
        <p class="text-lg sm:text-xl text-gray-300 max-w-xl mx-auto lg:mx-0">
          Q-Tune is the only precision chromatic tuner in the DIY pedal world. A bright touchscreen, studio-level accuracy, and firmware that keeps getting better. It assembles in 15&ndash;30 minutes with everyday hand tools, no soldering.
        </p>

        <!-- Above-the-fold buy CTA -->
        <div class="mt-7 flex flex-col items-center lg:items-start">
          <button
            class="buy-btn inline-flex items-center justify-center px-7 py-3.5 bg-amber-glow text-white text-base font-semibold rounded-lg hover:bg-amber-dark transition-all duration-200 shadow-lg hover:shadow-xl active:scale-[0.98]"
            data-url-us={qTuneProduct.stripeUrl}
          >
            {qTuneProduct.buttonLabel} &middot; ${qTuneProduct.price}
          </button>
          <p class="mt-3 text-sm text-gray-400 max-w-md">
            Ships June&ndash;July 2026 &middot; full refund if we miss the window &middot; free US shipping
          </p>
        </div>
      </div>

      <!-- Hero image: transparent pedal cut-out floating on the dark section -->
      <div class="relative flex-shrink-0 w-full max-w-md lg:max-w-lg mx-auto">
        <!-- Soft outer halo -->
        <div
          class="absolute left-1/2 top-1/2 w-[115%] aspect-square -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-600/15 blur-3xl"
          aria-hidden="true"
        ></div>
        <!-- Brighter glow behind the screen -->
        <div
          class="absolute left-1/2 top-[42%] w-2/3 aspect-square -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-500/30 blur-2xl"
          aria-hidden="true"
        ></div>
        <img
          src="/assets/images/q-tune-hero.webp"
          alt="Q-Tune DIY guitar tuner pedal kit with the tuning display lit"
          width="1400"
          height="1400"
          class="relative w-full h-auto"
        />
      </div>
    </div>
  </div>
</section>
