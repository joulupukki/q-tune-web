---
import NavLink from './NavLink.astro';
import { navigation } from '../data/navigation';

const currentPath = Astro.url.pathname;

const isActive = (href?: string) => {
  if (!href) return false;
  return currentPath === href || currentPath === href.replace(/\/$/, '');
};

const hasActiveChild = (children?: { href?: string }[]) =>
  !!children?.some((c) => isActive(c.href));
---

<header class="sticky top-0 z-50 border-b border-dark-border bg-dark-bg/95 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center transition-opacity hover:opacity-80" aria-label="Q-Tune home">
        <img
          src="/assets/images/q-tune-logo-white.png"
          alt="Q-Tune"
          width="788"
          height="199"
          class="h-8 w-auto"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navigation.map((item) => (
          item.children ? (
            <div class="relative group">
              <button
                type="button"
                class:list={[
                  'relative flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors duration-200',
                  hasActiveChild(item.children) ? 'text-amber-light' : 'text-gray-400 hover:text-white group-hover:text-white',
                ]}
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-3 h-3 mt-0.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
                {hasActiveChild(item.children) && (
                  <span class="absolute bottom-0 left-3 right-6 h-0.5 bg-amber-light rounded-full" />
                )}
              </button>
              <!-- Dropdown -->
              <div class="absolute left-0 top-full min-w-[12rem] pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-opacity duration-150">
                <div class="rounded-lg border border-dark-border bg-dark-surface shadow-lg py-2">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2 text-sm font-medium transition-colors',
                        isActive(child.href)
                          ? 'text-amber-light bg-dark-card'
                          : 'text-gray-400 hover:text-white hover:bg-dark-card',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <NavLink href={item.href!} label={item.label} />
          )
        ))}
        <a
          href="/#buy"
          class="ml-2 inline-flex items-center px-4 py-2 rounded-lg bg-amber-glow text-white text-sm font-semibold hover:bg-amber-dark hover:text-white transition-colors"
        >
          Buy
        </a>
      </nav>

      <!-- Mobile: Buy + hamburger -->
      <div class="flex items-center gap-2 md:hidden">
        <a
          href="/#buy"
          class="inline-flex items-center px-3 py-1.5 rounded-lg bg-amber-glow text-white text-sm font-semibold hover:bg-amber-dark hover:text-white transition-colors"
        >
          Buy
        </a>
        <button
          id="mobile-menu-btn"
          class="p-2 text-gray-400 hover:text-white transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-dark-border bg-dark-surface">
    <div class="px-4 py-3 space-y-1">
      {navigation.map((item) => (
        item.children ? (
          <div class="pt-2">
            <div class="px-3 pt-2 pb-1 text-xs font-semibold uppercase tracking-wide text-text-muted">
              {item.label}
            </div>
            {item.children.map((child) => (
              <a
                href={child.href}
                class:list={[
                  'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                  isActive(child.href)
                    ? 'text-amber-light bg-dark-card'
                    : 'text-gray-400 hover:text-white hover:bg-dark-card',
                ]}
              >
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'text-amber-light bg-dark-card'
                : 'text-gray-400 hover:text-white hover:bg-dark-card',
            ]}
          >
            {item.label}
          </a>
        )
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const close = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    hamburger?.classList.toggle('hidden', isOpen);
    close?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
